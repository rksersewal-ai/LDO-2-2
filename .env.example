# ─── LDO-2 EDMS — Root Environment Template ───────────────────────────────────
# Copy to .env and fill in values before running docker-compose or scripts.
# Never commit the real .env file to version control.

# ── Django Backend ─────────────────────────────────────────────────────────────
# REQUIRED — generate with: python -c "import secrets; print(secrets.token_hex(50))"
DJANGO_SECRET_KEY=CHANGE_ME_generate_a_50char_hex_secret

DJANGO_DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
EDMS_DB_ENGINE=postgresql
POSTGRES_DB=edms
POSTGRES_USER=edms
POSTGRES_PASSWORD=CHANGE_ME_strong_password
# Full DATABASE_URL override (optional — auto-built from above in docker-compose)
# DATABASE_URL=postgresql://edms:password@localhost:5432/edms

# ── Redis / Celery ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to true to run Celery tasks synchronously (dev without Redis)
# CELERY_TASK_ALWAYS_EAGER=false

# ── CORS / Host config ───────────────────────────────────────────────────
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ── Frontend (Vite) ─────────────────────────────────────────────────────
# Set to true for local dev without backend running
VITE_ENABLE_DEV_MOCK_API=false
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://localhost:8420
PORT=5173

# ── AWS S3 (optional — document storage) ────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=
AWS_S3_REGION=us-east-1
# Use localstack for local S3 emulation:
# AWS_S3_ENDPOINT_URL=http://localhost:4566

# ── Elasticsearch (optional — full-text search) ──────────────────────────
ELASTICSEARCH_URL=
ELASTICSEARCH_INDEX_PREFIX=edms

# ── SMTP / Email (optional — notifications) ──────────────────────────────
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=noreply@example.com

# ── OCR (optional) ───────────────────────────────────────────────────────
# TESSERACT_CMD=/usr/bin/tesseract

# ── Webhooks (optional) ──────────────────────────────────────────────────
# WEBHOOK_ENDPOINTS=https://example.com/webhook1,https://example.com/webhook2

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# JSON=true for structured logs in production
EDMS_JSON_LOGGING=true
