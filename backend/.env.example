# Django Settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,testserver,edms.local
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
DJANGO_FILE_UPLOAD_MAX_MEMORY_SIZE=10485760
EDMS_JSON_LOGGING=True

# Database - SQLite (default)
EDMS_SQLITE_PATH=./db.sqlite3

# Database - PostgreSQL (optional)
# Uncomment to use PostgreSQL instead of SQLite
# EDMS_DB_ENGINE=postgresql
# POSTGRES_DB=edms_db
# POSTGRES_USER=edms_user
# POSTGRES_PASSWORD=secure_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# Or use DATABASE_URL instead:
# DATABASE_URL=postgresql://user:password@host:5432/edms_db

# OCR
TESSERACT_CMD=/usr/bin/tesseract

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=false
EDMS_HASH_BACKFILL_INTERVAL_MINUTES=0
EDMS_HASH_BACKFILL_BATCH_SIZE=500
EDMS_HASH_BACKFILL_FORCE_FULL_HASH=false

# Object Storage (optional - local media remains the development fallback)
EDMS_OBJECT_STORAGE_BUCKET=
EDMS_OBJECT_STORAGE_ENDPOINT=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173
CSRF_TRUSTED_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-app-password

# Webhooks (optional)
# WEBHOOK_ENDPOINTS=https://example.com/webhook1
